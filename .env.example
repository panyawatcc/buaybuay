###############################################################################
# adbot-ai-product — environment variables template
#
# DO NOT commit a populated .env file. These values live in Cloudflare Pages
# Secrets (set via `bunx wrangler pages secret put <NAME>`) and are injected
# at runtime. This file is just for reference + local dev.
###############################################################################


########################################
# Required — app will not boot without these
########################################

# License JWT issued by Adbot at purchase. Ships in welcome email;
# starts with 'eyJ...' Must match the domain in ADBOT_DOMAIN below.
ADBOT_LICENSE_JWT=

# Your public domain — full hostname, no scheme, no trailing slash.
# Examples: abc-ads.pages.dev  OR  app.yourcompany.com
# MUST match the domain Adbot used when issuing your license.
ADBOT_DOMAIN=

# Adbot brain URL. Default is the production endpoint — only override if
# Adbot gave you a staging URL. Also configurable in wrangler.toml [vars].
ADBOT_BRAIN_URL=https://api.adbot.io

# Anthropic Claude API key. Your own — Adbot never stores it. Ships with
# every AI call through the Adbot brain proxy to Anthropic.
# Starts with 'sk-ant-api03-...' — from https://console.anthropic.com
#
# OPTIONAL at install time. The app boots fine without it — non-AI
# features (dashboard, rules, FB campaign management) work regardless.
# Required only for AI features (copywriter, rule-suggest, trend-spotter).
# Add later via:
#   bunx wrangler pages secret put ANTHROPIC_API_KEY --project-name <your-slug>
ANTHROPIC_API_KEY=

# Random 64-char hex. Used to sign HttpOnly session JWTs.
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_64_char_hex

# Random 64-char hex. Used to AES-encrypt Facebook tokens at rest in D1.
# Generate: openssl rand -hex 32
# ⚠️ Treat as ultra-sensitive — rotating this invalidates every stored FB token.
TOKEN_ENCRYPTION_KEY=change_me_64_char_hex

# Your Facebook App ID — from https://developers.facebook.com/apps/
# See META_DEV_CONSOLE.md for full setup walk-through.
FB_APP_ID=your_fb_app_id

# Your Facebook App Secret (never log this; never send it to the browser).
FB_APP_SECRET=your_fb_app_secret

# Full URL of THIS deployment's OAuth callback endpoint. Must match EXACTLY
# what you registered in Meta Dev Console → App Settings → Facebook Login →
# Valid OAuth Redirect URIs.
# Example: https://adbot.example.com/api/auth/callback
FB_REDIRECT_URI=https://your-domain/api/auth/callback

# Public origin of THIS deployment. Used for CORS on the ad-image proxy.
# Example: https://adbot.example.com
# If omitted, the ad-image proxy uses `*` (safe since images carry no credentials).
PUBLIC_ORIGIN=https://your-domain


########################################
# Strongly recommended
########################################

# Random 32+ char string. Required if you wire up an external cron service
# (GitHub Actions, cron-job.org, UptimeRobot, etc.) to POST /api/rules/evaluate.
# The cron endpoint checks `X-Cron-Secret` header against this.
CRON_SECRET=change_me_random_string


########################################
# Telegram alerts (optional but useful)
########################################

# BotFather token. Per-user bots can also be added via the Settings page,
# but this env var is used as a global fallback if a user hasn't configured
# their own bot.
TELEGRAM_BOT_TOKEN=

# Default chat id for the global bot. Per-user configured chats override this.
TELEGRAM_CHAT_ID=

# Shared secret for Telegram webhook verification. Optional.
TELEGRAM_WEBHOOK_SECRET=


########################################
# Email — invites, password resets (optional)
########################################

# https://resend.com API key. If not set, invite emails are skipped.
RESEND_API_KEY=


########################################
# AI features (optional — only needed if AI features are enabled)
########################################

# Anthropic Claude API key (sk-ant-api03-...). Used by:
# - post-booster copy generation
# - copywriter
# - CRM intake
# - trend spotter
# - retargeting / LTV helpers
ANTHROPIC_API_KEY=

# "1" to disable ALL AI features globally (useful during incidents).
LLM_DISABLED=

# CSV allowlist of Claude model ids; empty = allow all.
LLM_ALLOWED_MODELS=

# Max input tokens per LLM call (defensive — caps runaway prompts).
LLM_MAX_INPUT_TOKENS=8000

# Global cost rate limits (integers in USD micros; 1,000,000 = $1.00).
LLM_GLOBAL_DAILY_COST_USD_MICRO=5000000
LLM_GLOBAL_HOURLY_COST_USD_MICRO=1000000

# Per-user rate limits.
LLM_USER_DAILY_COST_USD_MICRO=500000
LLM_USER_DAILY_LIMIT=50
LLM_USER_HOURLY_LIMIT=20

# Alert threshold (per-mille of daily budget consumed).
LLM_GLOBAL_ALERT_THRESHOLD_PERMIL=800


########################################
# CRM webhook (optional — only if you wire up external CRM)
########################################

# Shared secret for the CRM → this-app webhook signature verification.
CRM_WEBHOOK_SECRET=


########################################
# DEBUG — only set in non-prod
########################################

# "1" enables verbose rule evaluator logging. Keep OFF in production.
DEBUG_RULES=
